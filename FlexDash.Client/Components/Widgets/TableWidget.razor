@using FlexDash.Client.Models

<div class="widget-card">
    <h3>@Title</h3>
    @if (DataPoints is { Length: > 0 })
    {
        <div style="overflow-x:auto; flex:1;">
            <table class="table">
                <thead>
                    <tr>
                        <th>Time</th>
                        <th>Value</th>
                        <th>Label</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var point in DataPoints.OrderByDescending(p => p.Timestamp).Take(20))
                    {
                        <tr>
                            <td>@point.Timestamp.ToLocalTime().ToString("HH:mm:ss")</td>
                            <td>@point.Value.ToString("F2")</td>
                            <td>@(point.Label ?? "—")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
    else
    {
        <div class="stat-card-label">Waiting for data...</div>
    }
</div>

@code {
    [Parameter] public string Title { get; set; } = "";
    [Parameter] public DataPointDto[]? DataPoints { get; set; }
}
